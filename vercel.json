{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/the-project", "destination": "/whats-proposed", "permanent": true },
    { "source": "/the-project.html", "destination": "/whats-proposed", "permanent": true },
    { "source": "/the-annexation", "destination": "/background", "permanent": true },
    { "source": "/the-annexation.html", "destination": "/background", "permanent": true },
    { "source": "/faq", "destination": "/myths", "permanent": true },
    { "source": "/faq.html", "destination": "/myths", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|jpeg|gif|webp|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
